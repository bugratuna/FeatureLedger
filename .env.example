# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=feature_ledger

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')|head -c 128"
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRY=15m

JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_REFRESH_EXPIRY=30d

# ─── Webhooks ─────────────────────────────────────────────────────────────────
# Used to HMAC-sign outbound webhook payloads (SHA-256)
WEBHOOK_SIGNING_SECRET=replace-with-a-webhook-signing-secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for development
CORS_ORIGIN=*

# ─── Rate limiting ────────────────────────────────────────────────────────────
THROTTLE_AUTH_LIMIT=20
THROTTLE_AUTH_TTL_MS=60000
